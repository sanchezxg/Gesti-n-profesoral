@page "/maestro-detalle"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <div class="card shadow-sm mb-4 border-dark">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0"><i class="bi bi-person-badge"></i> Maestro: Selección de Docente</h4>
        </div>
        <div class="card-body bg-light">
            <label class="fw-bold">Docente:</label>
            <select class="form-select border-primary" @onchange="OnDocenteCambiado">
                <option value="0">-- Seleccione un Docente --</option>
                @foreach (var d in listaDocentes)
                {
                    <option value="@d["cedula"]">@d["nombres"] @d["apellidos"] (C.C. @d["cedula"])</option>
                }
            </select>
        </div>
    </div>

    @if (cedulaSeleccionada > 0)
    {
        <div class="card shadow border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Estudios de @nombreDocenteSeleccionado</h5>
                <button class="btn btn-light btn-sm fw-bold" @onclick="NuevoEstudio">
                    <i class="bi bi-plus-circle"></i> Agregar Estudio
                </button>
            </div>
            <div class="card-body">

                @if (mostrarFormulario)
                {
                    <div class="card mb-4 border-warning shadow-sm bg-light">
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6"><label class="fw-bold">Título</label><input class="form-control" @bind="campoTitulo" /></div>
                                <div class="col-md-6"><label class="fw-bold">Universidad</label><input class="form-control" @bind="campoUniversidad" /></div>
                                <div class="col-md-3"><label class="fw-bold">Fecha</label><input type="date" class="form-control" @bind="campoFecha" /></div>
                                <div class="col-md-3"><label class="fw-bold">Tipo</label>
                                    <select class="form-select" @bind="campoTipo">
                                        <option value="Pregrado">Pregrado</option>
                                        <option value="Posgrado">Posgrado</option>
                                    </select>
                                </div>
                                <div class="col-md-3"><label class="fw-bold">Metodología</label><input class="form-control" @bind="campoMetodologia" /></div>
                                <div class="col-md-3"><label class="fw-bold">País</label><input class="form-control" @bind="campoPais" /></div>
                                <div class="col-md-6"><label class="fw-bold">Ciudad</label><input class="form-control" @bind="campoCiudad" /></div>
                                <div class="col-md-6 d-flex align-items-center mt-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" @bind="campoAcreditada">
                                        <label class="form-check-label fw-bold ms-2">¿Acreditada?</label>
                                    </div>
                                </div>
                                <div class="col-12"><label class="fw-bold">Perfil Egresado</label><textarea class="form-control" @bind="campoPerfil"></textarea></div>
                            </div>
                            <div class="mt-3 text-end">
                                <button class="btn btn-success" @onclick="GuardarEstudio"><i class="bi bi-save"></i> Guardar</button>
                                <button class="btn btn-secondary" @onclick="() => mostrarFormulario = false">Cancelar</button>
                            </div>
                        </div>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Título / Universidad</th>
                                <th>Fecha</th>
                                <th class="text-center">Acreditación</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var est in estudiosFiltrados)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@est["titulo"]</div>
                                        <small class="text-muted">@est["universidad"]</small>
                                    </td>
                                    <td>@Convert.ToDateTime(est["fecha"]).ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        @if (Convert.ToBoolean(est["ins_acreditada"]))
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> ACREDITADA</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x-circle"></i> NO ACREDITADA</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            @* Botones con color sólido para asegurar visibilidad *@
                                            <button class="btn btn-warning btn-sm" @onclick="() => EditarEstudio(est)">
                                                <i class="bi bi-pencil-square text-white"></i>
                                            </button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarEstudio(est)">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> listaDocentes = new();
    private List<Dictionary<string, object?>> estudiosFiltrados = new();
    private int cedulaSeleccionada = 0;
    private string nombreDocenteSeleccionado = "";
    private bool mostrarFormulario = false, editando = false;

    // Campos
    private int campoId;
    private string campoTitulo = "", campoUniversidad = "", campoTipo = "Pregrado", campoMetodologia = "", campoPerfil = "", campoCiudad = "", campoPais = "Colombia";
    private bool campoAcreditada = false;
    private DateTime campoFecha = DateTime.Now;

    protected override async Task OnInitializedAsync() => listaDocentes = await Api.ListarAsync("docente");

    private async Task OnDocenteCambiado(ChangeEventArgs e) {
        cedulaSeleccionada = int.Parse(e.Value?.ToString() ?? "0");
        if (cedulaSeleccionada > 0) {
            var d = listaDocentes.FirstOrDefault(x => x["cedula"]?.ToString() == cedulaSeleccionada.ToString());
            nombreDocenteSeleccionado = $"{d?["nombres"]} {d?["apellidos"]}";
            await CargarEstudios();
        }
    }

    private async Task CargarEstudios() {
        var todos = await Api.ListarAsync("estudios_realizados");
        estudiosFiltrados = todos.Where(x => x["docente"]?.ToString() == cedulaSeleccionada.ToString()).ToList();
    }

    private void NuevoEstudio() { editando = false; LimpiarCampos(); mostrarFormulario = true; }

    private void EditarEstudio(Dictionary<string, object?> est) {
        editando = true;
        campoId = int.Parse(est["id"]?.ToString() ?? "0");
        campoTitulo = est["titulo"]?.ToString() ?? "";
        campoUniversidad = est["universidad"]?.ToString() ?? "";
        campoTipo = est["tipo"]?.ToString() ?? "";
        campoMetodologia = est["metodologia"]?.ToString() ?? "";
        campoPerfil = est["perfil_egresado"]?.ToString() ?? "";
        campoCiudad = est["ciudad"]?.ToString() ?? "";
        campoPais = est["pais"]?.ToString() ?? "";
        campoAcreditada = Convert.ToBoolean(est["ins_acreditada"]);
        campoFecha = DateTime.TryParse(est["fecha"]?.ToString(), out var f) ? f : DateTime.Now;
        mostrarFormulario = true;
    }

    private async Task GuardarEstudio() {
        var d = new Dictionary<string, object?> {
            ["titulo"] = campoTitulo, ["universidad"] = campoUniversidad, ["fecha"] = campoFecha.ToString("yyyy-MM-dd"),
            ["tipo"] = campoTipo, ["ciudad"] = campoCiudad, ["docente"] = cedulaSeleccionada,
            ["ins_acreditada"] = campoAcreditada ? 1 : 0, ["metodologia"] = campoMetodologia,
            ["perfil_egresado"] = campoPerfil, ["pais"] = campoPais
        };
        if (editando) await Api.ActualizarAsync("estudios_realizados", "id", campoId.ToString(), d);
        else await Api.CrearAsync("estudios_realizados", d);
        mostrarFormulario = false; await CargarEstudios();
    }

    private async Task EliminarEstudio(Dictionary<string, object?> est) {
        await Api.EliminarAsync("estudios_realizados", "id", est["id"]?.ToString() ?? "");
        await CargarEstudios();
    }

    private void LimpiarCampos() {
        campoTitulo = ""; campoUniversidad = ""; campoMetodologia = ""; campoPerfil = ""; campoCiudad = ""; campoAcreditada = false;
    }
}
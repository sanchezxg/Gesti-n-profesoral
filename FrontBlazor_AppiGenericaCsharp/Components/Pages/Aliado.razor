@page "/aliado"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Aliados</PageTitle>

<div class="container mt-4">
    <h3>Aliados</h3>

    @* ───────── ALERTA DE EXITO O ERROR ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ALIADO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Aliado</button>
    }

    @* ───────── FORMULARIO CREAR / EDITAR ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Aliado" : "Nuevo Aliado")
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">NIT</label>
                        <input class="form-control" type="number" @bind="campoNit" disabled="@editando"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Razón Social</label>
                        <input class="form-control" @bind="campoRazonSocial"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre Contacto</label>
                        <input class="form-control" @bind="campoNombreContacto"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Correo</label>
                        <input class="form-control" @bind="campoCorreo"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Teléfono</label>
                        <input class="form-control" @bind="campoTelefono"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Ciudad</label>
                        <input class="form-control" @bind="campoCiudad"/>
                    </div>

                </div>

                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>

            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary"></div>
        </div>
    }

    @* ───────── TABLA DE ALIADOS ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">

            <thead class="table-dark">
                <tr>
                    <th>NIT</th>
                    <th>Razón Social</th>
                    <th>Contacto</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th>Ciudad</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var reg in registros)
                {
                    <tr>

                        <td>@reg["nit"]</td>
                        <td>@reg["razon_social"]</td>
                        <td>@reg["nombre_contacto"]</td>
                        <td>@reg["correo"]</td>
                        <td>@reg["telefono"]</td>
                        <td>@reg["ciudad"]</td>

                        <td>

                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">
                                Editar
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">
                                Eliminar
                            </button>

                        </td>

                    </tr>
                }

            </tbody>

        </table>
    }

    @* ───────── MENSAJE SIN DATOS ───────── *@
    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">
            No se encontraron registros en la tabla aliado.
        </div>
    }

</div>

@code {

    // ───────── VARIABLES ─────────

    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;

    private bool mostrarFormulario = false;

    private bool editando = false;

    private string mensaje = string.Empty;

    private bool exito = false;


    // CAMPOS FORMULARIO

    private long campoNit;

    private string campoRazonSocial = string.Empty;

    private string campoNombreContacto = string.Empty;

    private string campoCorreo = string.Empty;

    private string campoTelefono = string.Empty;

    private string campoCiudad = string.Empty;


    // ───────── CICLO DE VIDA ─────────

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }


    // ───────── METODOS ─────────

    private async Task CargarRegistros()
    {
        cargando = true;

        registros = await Api.ListarAsync("aliado");

        cargando = false;
    }


    private void NuevoRegistro()
    {
        editando = false;

        campoNit = 0;
        campoRazonSocial = "";
        campoNombreContacto = "";
        campoCorreo = "";
        campoTelefono = "";
        campoCiudad = "";

        mostrarFormulario = true;

        mensaje = string.Empty;
    }


    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;

        campoNit = long.TryParse(reg["nit"]?.ToString(), out long n) ? n : 0;

        campoRazonSocial = reg["razon_social"]?.ToString() ?? "";

        campoNombreContacto = reg["nombre_contacto"]?.ToString() ?? "";

        campoCorreo = reg["correo"]?.ToString() ?? "";

        campoTelefono = reg["telefono"]?.ToString() ?? "";

        campoCiudad = reg["ciudad"]?.ToString() ?? "";

        mostrarFormulario = true;

        mensaje = string.Empty;
    }


    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["nit"] = campoNit,
            ["razon_social"] = campoRazonSocial,
            ["nombre_contacto"] = campoNombreContacto,
            ["correo"] = campoCorreo,
            ["telefono"] = campoTelefono,
            ["ciudad"] = campoCiudad
        };

        if (editando)
        {
            datos.Remove("nit");

            var resultado = await Api.ActualizarAsync(
                "aliado",
                "nit",
                campoNit.ToString(),
                datos
            );

            exito = resultado.exito;

            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("aliado", datos);

            exito = resultado.exito;

            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;

            await CargarRegistros();
        }
    }


    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string nit = reg["nit"]?.ToString() ?? "";

        var resultado = await Api.EliminarAsync(
            "aliado",
            "nit",
            nit
        );

        exito = resultado.exito;

        mensaje = resultado.mensaje;

        if (exito)
        {
            await CargarRegistros();
        }
    }


    private void Cancelar()
    {
        mostrarFormulario = false;

        mensaje = string.Empty;
    }

}
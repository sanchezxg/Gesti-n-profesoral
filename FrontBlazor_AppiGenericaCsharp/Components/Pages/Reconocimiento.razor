@page "/Reconocimiento"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Reconocimiento</PageTitle>

<div class="container mt-4">
    <h3>Reconocimiento</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Reconocimiento</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar docente" : "Nuevo docente")
            </div>
            <div class="card-body">
                <div class="row">
                   
                                


                    <div class="col-md-6 mb-3">
                        <label class="form-label">Cedula docente</label>
                        <select class="form-select" @bind="campoDocente">
                            <option value="">-- Seleccione --</option>
                            @foreach (var d in docentes)
                            {
                                <option value="@d["cedula"]">@d["nombres"] (@d["cedula"])</option>
                            }
                        </select>
                    </div>
                
    
    
   
    <div class="col-md-6 mb-3">
        <label class="form-label">Tipo</label>
        <input class="form-control" @bind="campoTipo" />
      </div>
    <div class="col-md-6 mb-3">
        <label class="form-label">Fecha</label>
       <input type="date" class="form-control" @bind="campoFecha" />
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label">Institucion</label>
        <input class="form-control" @bind="campoInstitucion" />
    </div>
                 <div class="col-md-6 mb-3">
        <label class="form-label">nombre</label>
        <input class="form-control" @bind="campoNombre" />
    </div>  

    <div class="col-md-6 mb-3">
        <label class="form-label">ambito</label>
        <input class="form-control" @bind="campoAmbito" />
    </div>
                    
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                
<th>Id</th>
<th>tipo</th>
<th>fecha</th>
<th>institucion</th>
<th>nombre</th>
<th>ambito</th>
<th>docente</th>
  <th>Acciones</th>

                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                         
     
        <td>@reg["id"]</td>
        <td>@reg["tipo"]</td>
        <td>@reg["fecha"]</td>
           <td>@reg["institucion"]</td>
             <td>@reg["nombre"]</td>
                    <td>@reg["ambito"]</td>
        <td>@ObtenerDocente(reg["docente"]?.ToString())</td>
      
         
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla reconocimiento.</div>
    }
</div>

@code {

   
         private List<Dictionary<string, object?>> docentes = new();
        private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

   private string campoId = string.Empty;
private string campoTipo = string.Empty;
private DateTime  campoFecha ;

private string  campoInstitucion = string.Empty;

private string  campoNombre = string.Empty;

private string  campoAmbito = string.Empty;
private string  campoDocente = string.Empty;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
   

    docentes = await Api.ListarAsync("docente");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("reconocimiento");
        cargando = false;
    }

      private string ObtenerDocente(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "Sin persona";
        var cedula_docente = docentes.FirstOrDefault(p => p["cedula"]?.ToString() == id);
        return cedula_docente?["cedula"]?.ToString() ?? id;
    }


    private void NuevoRegistro()
    {
        editando = false;
          mostrarFormulario = true;
               mensaje = string.Empty;
          campoId = string.Empty;
  campoTipo = string.Empty;
   campoFecha=DateTime.Now; 

   campoInstitucion = string.Empty;

   campoNombre = string.Empty;

   campoAmbito = string.Empty;
  campoDocente = string.Empty;


    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
     
campoId = reg["id"]?.ToString() ?? "";
campoTipo = reg["tipo"]?.ToString() ?? "";



campoFecha = DateTime.TryParse(reg["fecha"]?.ToString(), out DateTime fn)
    ? fn : DateTime.Now;



campoInstitucion = reg["institucion"]?.ToString() ?? "";
campoNombre = reg["nombre"]?.ToString() ?? "";
campoAmbito = reg["ambito"]?.ToString() ?? "";
campoDocente = reg["docente"]?.ToString() ?? "";


        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
          
    ["tipo"] = campoTipo,
    ["fecha"] = campoFecha,
    ["institucion"] = campoInstitucion,
    ["nombre"] = campoNombre,
    ["ambito"] = campoAmbito,
    ["docente"] = campoDocente
  

        };

        if (editando)
        {
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de actualizar el Cliente #{campoId}?");
            if (!confirmar) return;
            var resultado = await Api.ActualizarAsync("reconocimiento", "id", campoId, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("reconocimiento", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["id"]?.ToString() ?? "";
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de eliminar el Cliente #{id}?");
        if (!confirmar) return;
        var resultado = await Api.EliminarAsync("reconocimiento", "id", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}
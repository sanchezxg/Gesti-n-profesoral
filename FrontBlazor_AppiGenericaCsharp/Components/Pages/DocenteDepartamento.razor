@page "/docentedepartamento"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Docente - Departamento</PageTitle>

<div class="container mt-4">
    <h3>Docente - Departamento</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Asignación</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Asignación" : "Nueva Asignación")
            </div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Docente</label>
                            <input class="form-control" value="@campoDocente" disabled />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Departamento</label>
                            <input class="form-control" value="@campoDepartamento" disabled />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Docente</label>
                            <select class="form-select" @bind="campoDocente">
                                <option value="">-- Seleccione --</option>
                                @foreach (var d in docentes)
                                {
                                    <option value="@d["cedula"]">@d["nombres"] @d["apellidos"] (@d["cedula"])</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Departamento (Programa)</label>
                            <select class="form-select" @bind="campoDepartamento">
                                <option value="">-- Seleccione --</option>
                                @foreach (var p in programas)
                                {
                                    <option value="@p["id"]">@p["nombre"] (@p["id"])</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Dedicación</label>
                        <input class="form-control" @bind="campoDedicacion" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Modalidad</label>
                        <input class="form-control" @bind="campoModalidad" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha Ingreso</label>
                        <input type="date" class="form-control" @bind="campoFechaIngreso" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha Salida (Opcional)</label>
                        <input type="date" class="form-control" @bind="campoFechaSalida" />
                    </div>
                    
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Docente</th>
                    <th>Departamento</th>
                    <th>Dedicación</th>
                    <th>Modalidad</th>
                    <th>Fecha Ingreso</th>
                    <th>Fecha Salida</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerDocente(reg["docente"]?.ToString())</td>
                        <td>@ObtenerPrograma(reg["departamento"]?.ToString())</td>
                        <td>@reg["dedicacion"]</td>
                        <td>@reg["modalidad"]</td>
                        <td>@reg["fecha_ingreso"]</td>
                        <td>@reg["fecha_salida"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla docente_departamento.</div>
    }
</div>

@code {

    private List<Dictionary<string, object?>> docentes = new();
    private List<Dictionary<string, object?>> programas = new();
    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private string campoDocente = string.Empty;
    private string campoDepartamento = string.Empty;
    private string campoDedicacion = string.Empty;
    private string campoModalidad = string.Empty;
    private DateTime campoFechaIngreso = DateTime.Now;
    private DateTime campoFechaSalida = DateTime.Now;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        docentes = await Api.ListarAsync("docente");
        programas = await Api.ListarAsync("programa");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("docente_departamento");
        cargando = false;
    }

    private string ObtenerDocente(string? cedula)
    {
        if (string.IsNullOrEmpty(cedula)) return "Sin docente";
        var docente = docentes.FirstOrDefault(d => d["cedula"]?.ToString() == cedula);
        return docente?["nombres"]?.ToString() + " " + docente?["apellidos"]?.ToString() ?? cedula;
    }

    private string ObtenerPrograma(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "Sin programa";
        var programa = programas.FirstOrDefault(p => p["id"]?.ToString() == id);
        return programa?["nombre"]?.ToString() ?? id;
    }

    private void NuevoRegistro()
    {
        editando = false;
        mostrarFormulario = true;
        mensaje = string.Empty;
        campoDocente = string.Empty;
        campoDepartamento = string.Empty;
        campoDedicacion = string.Empty;
        campoModalidad = string.Empty;
        campoFechaIngreso = DateTime.Now;
        campoFechaSalida = DateTime.Now;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoDocente = reg["docente"]?.ToString() ?? "";
        campoDepartamento = reg["departamento"]?.ToString() ?? "";
        campoDedicacion = reg["dedicacion"]?.ToString() ?? "";
        campoModalidad = reg["modalidad"]?.ToString() ?? "";
        campoFechaIngreso = DateTime.TryParse(reg["fecha_ingreso"]?.ToString(), out DateTime fi) ? fi : DateTime.Now;
        campoFechaSalida = DateTime.TryParse(reg["fecha_salida"]?.ToString(), out DateTime fs) ? fs : DateTime.Now;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["docente"] = campoDocente,
            ["departamento"] = campoDepartamento,
            ["dedicacion"] = campoDedicacion,
            ["modalidad"] = campoModalidad,
            ["fecha_ingreso"] = campoFechaIngreso,
            ["fecha_salida"] = campoFechaSalida
        };

        if (editando)
        {
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de actualizar la Asignación #{campoDocente}-{campoDepartamento}?");
            if (!confirmar) return;
            var resultado = await Api.ActualizarAsync("docente_departamento", "docente", campoDocente, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("docente_departamento", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["docente"]?.ToString() ?? "";
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de eliminar la Asignación #{id}?");
        if (!confirmar) return;
        var resultado = await Api.EliminarAsync("docente_departamento", "docente", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}
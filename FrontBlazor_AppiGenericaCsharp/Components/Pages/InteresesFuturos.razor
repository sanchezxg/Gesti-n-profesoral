@page "/interesesfuturos"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Intereses Futuros</PageTitle>

<div class="container mt-4">
    <h3>Intereses Futuros</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Interés</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Interés" : "Nuevo Interés")
            </div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Docente</label>
                            <input class="form-control" value="@campoDocente" disabled />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Término Clave</label>
                            <input class="form-control" value="@campoTerminoClave" disabled />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Docente</label>
                            <select class="form-select" @bind="campoDocente">
                                <option value="">-- Seleccione --</option>
                                @foreach (var d in docentes)
                                {
                                    <option value="@d["cedula"]">@d["nombres"] @d["apellidos"] (@d["cedula"])</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Término Clave</label>
                            <select class="form-select" @bind="campoTerminoClave">
                                <option value="">-- Seleccione --</option>
                                @foreach (var t in terminos)
                                {
                                    <option value="@t["termino"]">@t["termino"]</option>
                                }
                            </select>
                        </div>
                    }
                    
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Docente</th>
                    <th>Término Clave</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerDocente(reg["docente"]?.ToString())</td>
                        <td>@ObtenerTermino(reg["termino_clave"]?.ToString())</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla intereses_futuros.</div>
    }
</div>

@code {

    private List<Dictionary<string, object?>> docentes = new();
    private List<Dictionary<string, object?>> terminos = new();
    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private string campoDocente = string.Empty;
    private string campoTerminoClave = string.Empty;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        docentes = await Api.ListarAsync("docente");
        terminos = await Api.ListarAsync("termino_clave");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("intereses_futuros");
        cargando = false;
    }

    private string ObtenerDocente(string? cedula)
    {
        if (string.IsNullOrEmpty(cedula)) return "Sin docente";
        var docente = docentes.FirstOrDefault(d => d["cedula"]?.ToString() == cedula);
        return docente?["nombres"]?.ToString() + " " + docente?["apellidos"]?.ToString() ?? cedula;
    }

    private string ObtenerTermino(string? termino)
    {
        if (string.IsNullOrEmpty(termino)) return "Sin término";
        var term = terminos.FirstOrDefault(t => t["termino"]?.ToString() == termino);
        return term?["termino"]?.ToString() ?? termino;
    }

    private void NuevoRegistro()
    {
        editando = false;
        mostrarFormulario = true;
        mensaje = string.Empty;
        campoDocente = string.Empty;
        campoTerminoClave = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoDocente = reg["docente"]?.ToString() ?? "";
        campoTerminoClave = reg["termino_clave"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["docente"] = campoDocente,
            ["termino_clave"] = campoTerminoClave
        };

        if (editando)
        {
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de actualizar el Interés #{campoDocente}-{campoTerminoClave}?");
            if (!confirmar) return;
            var resultado = await Api.ActualizarAsync("intereses_futuros", "docente", campoDocente, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("intereses_futuros", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["docente"]?.ToString() ?? "";
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de eliminar el Interés #{id}?");
        if (!confirmar) return;
        var resultado = await Api.EliminarAsync("intereses_futuros", "docente", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}
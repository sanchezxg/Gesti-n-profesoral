@page "/alianza"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Alianzas</PageTitle>

<div class="container mt-4">
    <h3>Alianzas</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Alianza</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Alianza" : "Nueva Alianza")
            </div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Aliado</label>
                            <input class="form-control" value="@campoAliado" disabled />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Departamento</label>
                            <input class="form-control" value="@campoDepartamento" disabled />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Aliado</label>
                            <select class="form-select" @bind="campoAliado">
                                <option value="">-- Seleccione --</option>
                                @foreach (var a in aliados)
                                {
                                    <option value="@a["nit"]">@a["razon_social"] (@a["nit"])</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Departamento (Programa)</label>
                            <select class="form-select" @bind="campoDepartamento">
                                <option value="">-- Seleccione --</option>
                                @foreach (var p in programas)
                                {
                                    <option value="@p["id"]">@p["nombre"] (@p["id"])</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input type="date" class="form-control" @bind="campoFechaInicio" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input type="date" class="form-control" @bind="campoFechaFin" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Docente (Opcional)</label>
                        <select class="form-select" @bind="campoDocente">
                            <option value="">-- Sin docente --</option>
                            @foreach (var d in docentes)
                            {
                                <option value="@d["cedula"]">@d["nombres"] @d["apellidos"] (@d["cedula"])</option>
                            }
                        </select>
                    </div>
                    
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Aliado</th>
                    <th>Departamento</th>
                    <th>Fecha Inicio</th>
                    <th>Fecha Fin</th>
                    <th>Docente</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerAliado(reg["aliado"]?.ToString())</td>
                        <td>@ObtenerPrograma(reg["departamento"]?.ToString())</td>
                        <td>@reg["fecha_inicio"]</td>
                        <td>@reg["fecha_fin"]</td>
                        <td>@ObtenerDocente(reg["docente"]?.ToString())</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla alianza.</div>
    }
</div>

@code {

    private List<Dictionary<string, object?>> aliados = new();
    private List<Dictionary<string, object?>> programas = new();
    private List<Dictionary<string, object?>> docentes = new();
    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private string campoAliado = string.Empty;
    private string campoDepartamento = string.Empty;
    private DateTime campoFechaInicio = DateTime.Now;
    private DateTime campoFechaFin = DateTime.Now;
    private string campoDocente = string.Empty;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        aliados = await Api.ListarAsync("aliado");
        programas = await Api.ListarAsync("programa");
        docentes = await Api.ListarAsync("docente");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("alianza");
        cargando = false;
    }

    private string ObtenerAliado(string? nit)
    {
        if (string.IsNullOrEmpty(nit)) return "Sin aliado";
        var aliado = aliados.FirstOrDefault(a => a["nit"]?.ToString() == nit);
        return aliado?["razon_social"]?.ToString() ?? nit;
    }

    private string ObtenerPrograma(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "Sin programa";
        var programa = programas.FirstOrDefault(p => p["id"]?.ToString() == id);
        return programa?["nombre"]?.ToString() ?? id;
    }

    private string ObtenerDocente(string? cedula)
    {
        if (string.IsNullOrEmpty(cedula)) return "Sin docente";
        var docente = docentes.FirstOrDefault(d => d["cedula"]?.ToString() == cedula);
        return docente?["nombres"]?.ToString() + " " + docente?["apellidos"]?.ToString() ?? cedula;
    }

    private void NuevoRegistro()
    {
        editando = false;
        mostrarFormulario = true;
        mensaje = string.Empty;
        campoAliado = string.Empty;
        campoDepartamento = string.Empty;
        campoFechaInicio = DateTime.Now;
        campoFechaFin = DateTime.Now;
        campoDocente = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoAliado = reg["aliado"]?.ToString() ?? "";
        campoDepartamento = reg["departamento"]?.ToString() ?? "";
        campoFechaInicio = DateTime.TryParse(reg["fecha_inicio"]?.ToString(), out DateTime fi) ? fi : DateTime.Now;
        campoFechaFin = DateTime.TryParse(reg["fecha_fin"]?.ToString(), out DateTime ff) ? ff : DateTime.Now;
        campoDocente = reg["docente"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["aliado"] = campoAliado,
            ["departamento"] = campoDepartamento,
            ["fecha_inicio"] = campoFechaInicio,
            ["fecha_fin"] = campoFechaFin,
            ["docente"] = string.IsNullOrEmpty(campoDocente) ? null : campoDocente
        };

        if (editando)
        {
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de actualizar la Alianza #{campoAliado}-{campoDepartamento}?");
            if (!confirmar) return;
            var resultado = await Api.ActualizarAsync("alianza", "aliado", campoAliado, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("alianza", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["aliado"]?.ToString() ?? "";
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de eliminar la Alianza #{id}?");
        if (!confirmar) return;
        var resultado = await Api.EliminarAsync("alianza", "aliado", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}
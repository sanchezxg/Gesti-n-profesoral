@page "/usuarios"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Usuarios</PageTitle>

<div class="container mt-4">
    <h3>Usuarios</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Usuario</button>
    }

    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Usuario" : "Nuevo Usuario")
            </div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input class="form-control" value="@campoEmail" disabled />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input class="form-control" type="email" @bind="campoEmail" />
                        </div>
                    }

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Contrasena</label>
                        <input class="form-control" type="password" @bind="campoContrasena" placeholder="@(editando ? "Dejar vacío para no cambiar" : "")" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Activo</label>
                        <select class="form-select" @bind="campoActivo">
                            <option value="true">Si</option>
                            <option value="false">No</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Email</th>
                    <th>Nombre</th>
                    <th>Activo</th>
                    <th>Debe Cambiar</th>
                    <th>Ultimo Acceso</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["email"]</td>
                        <td>@reg["nombre"]</td>
                        <td>@(reg["activo"]?.ToString() == "True" ? "Si" : "No")</td>
                        <td>@(reg["debe_cambiar_contrasena"]?.ToString() == "True" ? "Si" : "No")</td>
                        <td>@reg["ultimo_acceso"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla usuarios.</div>
    }
</div>

@code {

    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private string campoEmail = string.Empty;
    private string campoNombre = string.Empty;
    private string campoContrasena = string.Empty;
    private string campoActivo = "true";
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("usuarios");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        mostrarFormulario = true;
        mensaje = string.Empty;
        campoEmail = string.Empty;
        campoNombre = string.Empty;
        campoContrasena = string.Empty;
        campoActivo = "true";
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoEmail = reg["email"]?.ToString() ?? "";
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoContrasena = "";
        campoActivo = reg["activo"]?.ToString() == "True" ? "true" : "false";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["email"] = campoEmail,
            ["nombre"] = campoNombre,
            ["activo"] = campoActivo == "true"
        };

        string? encriptar = null;
        if (!string.IsNullOrEmpty(campoContrasena))
        {
            datos["contrasena"] = campoContrasena;
            encriptar = "contrasena";
        }

        if (editando)
        {
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"Esta seguro de actualizar el usuario {campoEmail}?");
            if (!confirmar) return;
            var resultado = await Api.ActualizarAsync("usuarios", "email", campoEmail, datos, encriptar);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("usuarios", datos, encriptar);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string email = reg["email"]?.ToString() ?? "";
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"Esta seguro de eliminar el usuario {email}?");
        if (!confirmar) return;
        var resultado = await Api.EliminarAsync("usuarios", "email", email);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}

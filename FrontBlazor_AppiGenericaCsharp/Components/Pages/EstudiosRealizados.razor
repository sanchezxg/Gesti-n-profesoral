@page "/estudios-realizados"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Estudios Realizados</PageTitle>

<div class="container mt-4">
    <h3>Estudios Realizados</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Estudio</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-dark text-white">@(editando ? "Editar Registro" : "Nuevo Registro")</div>
            <div class="card-body">
                <div class="row">
                    @* Solo mostramos el ID si estamos editando, ya que SQL lo genera al crear *@
                    @if (editando)
                    {
                        <div class="col-md-2 mb-3">
                            <label class="form-label">ID</label>
                            <input class="form-control" value="@campoId" disabled />
                        </div>
                    }
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Título</label>
                        <input class="form-control" @bind="campoTitulo" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Cédula Docente</label>
                        <input class="form-control" type="number" @bind="campoDocente" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Universidad</label>
                        <input class="form-control" @bind="campoUniversidad" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Fecha Grado</label>
                        <input class="form-control" type="date" @bind="campoFecha" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" placeholder="Pregrado/Posgrado" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>ID</th><th>Título</th><th>Docente</th><th>Universidad</th><th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["titulo"]</td>
                        <td>@reg["docente"]</td>
                        <td>@reg["universidad"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty;

    private int campoId; // Se usa para el Update
    private int campoDocente;
    private string campoTitulo = "", campoUniversidad = "", campoTipo = "";
    private DateTime campoFecha = DateTime.Now;

    protected override async Task OnInitializedAsync() => await CargarRegistros();

    private async Task CargarRegistros() {
        cargando = true;
        registros = await Api.ListarAsync("estudios_realizados");
        cargando = false;
    }

    private void NuevoRegistro() {
        editando = false; campoId = 0; campoTitulo = ""; campoUniversidad = ""; 
        mostrarFormulario = true; mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg) {
        editando = true;
        campoId = int.Parse(reg["id"]?.ToString() ?? "0");
        campoTitulo = reg["titulo"]?.ToString() ?? "";
        campoDocente = int.Parse(reg["docente"]?.ToString() ?? "0");
        campoUniversidad = reg["universidad"]?.ToString() ?? "";
        campoFecha = DateTime.TryParse(reg["fecha"]?.ToString(), out var f) ? f : DateTime.Now;
        campoTipo = reg["tipo"]?.ToString() ?? "";
        mostrarFormulario = true;
    }

    private async Task GuardarRegistro() {
        // Diccionario de datos SIN el campo 'id'
        var datos = new Dictionary<string, object?> {
            ["titulo"] = campoTitulo,
            ["universidad"] = campoUniversidad,
            ["fecha"] = campoFecha.ToString("yyyy-MM-dd"),
            ["tipo"] = campoTipo,
            ["docente"] = campoDocente,
            ["ins_acreditada"] = 1,
            ["ciudad"] = "N/A", // Campos requeridos por el script
            ["pais"] = "Colombia"
        };

        if (editando) {
            // Actualizar: Pasamos el ID por fuera del diccionario
            var res = await Api.ActualizarAsync("estudios_realizados", "id", campoId.ToString(), datos);
            exito = res.exito; mensaje = res.mensaje;
        }
        else {
            // Crear: La DB genera el ID automáticamente
            var res = await Api.CrearAsync("estudios_realizados", datos);
            exito = res.exito; mensaje = res.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg) {
        var res = await Api.EliminarAsync("estudios_realizados", "id", reg["id"]?.ToString() ?? "");
        exito = res.exito; mensaje = res.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() => mostrarFormulario = false;
}
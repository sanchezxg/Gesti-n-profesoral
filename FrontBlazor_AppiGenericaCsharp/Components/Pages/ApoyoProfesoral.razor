@page "/apoyo-profesoral"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Apoyo Profesoral</PageTitle>

<div class="container mt-4">
    <h3>Apoyo Profesoral</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">
            Nuevo Registro
        </button>
    }

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Apoyo Profesoral" : "Nuevo Apoyo Profesoral")
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Estudios (ID)</label>
                        <input class="form-control"
                               type="number"
                               @bind="campoEstudios"
                               disabled="@editando" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Con Apoyo</label>
                        <select class="form-control" @bind="campoConApoyo">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Institución</label>
                        <input class="form-control"
                               @bind="campoInstitucion" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control"
                               @bind="campoTipo" />
                    </div>

                </div>

                <button class="btn btn-success me-2"
                        @onclick="GuardarRegistro">
                    Guardar
                </button>

                <button class="btn btn-secondary"
                        @onclick="Cancelar">
                    Cancelar
                </button>

            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">

            <thead class="table-dark">
                <tr>
                    <th>Estudios</th>
                    <th>Con Apoyo</th>
                    <th>Institución</th>
                    <th>Tipo</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var reg in registros)
                {
                    <tr>

                        <td>@reg["estudios"]</td>

                        <td>
                            @(reg["con_apoyo"]?.ToString() == "True" ? "Sí" : "No")
                        </td>

                        <td>@reg["institucion"]</td>

                        <td>@reg["tipo"]</td>

                        <td>

                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">
                                Editar
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">
                                Eliminar
                            </button>

                        </td>

                    </tr>
                }

            </tbody>

        </table>
    }

    @* ───────── SIN DATOS ───────── *@
    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">
            No se encontraron registros en apoyo_profesoral.
        </div>
    }

</div>

@code {

    // ───────── VARIABLES ─────────

    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;

    private bool mostrarFormulario = false;

    private bool editando = false;

    private string mensaje = string.Empty;

    private bool exito = false;

    // Campos formulario

    private int campoEstudios = 0;

    private bool campoConApoyo = false;

    private string campoInstitucion = string.Empty;

    private string campoTipo = string.Empty;


    // ───────── CICLO DE VIDA ─────────

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }


    // ───────── METODOS ─────────

    private async Task CargarRegistros()
    {
        cargando = true;

        registros = await Api.ListarAsync("apoyo_profesoral");

        cargando = false;
    }


    private void NuevoRegistro()
    {
        editando = false;

        campoEstudios = 0;
        campoConApoyo = false;
        campoInstitucion = string.Empty;
        campoTipo = string.Empty;

        mostrarFormulario = true;

        mensaje = string.Empty;
    }


    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;

        campoEstudios = int.TryParse(reg["estudios"]?.ToString(), out int e) ? e : 0;

        campoConApoyo = reg["con_apoyo"]?.ToString() == "True";

        campoInstitucion = reg["institucion"]?.ToString() ?? "";

        campoTipo = reg["tipo"]?.ToString() ?? "";

        mostrarFormulario = true;

        mensaje = string.Empty;
    }


    private async Task GuardarRegistro()
    {

        var datos = new Dictionary<string, object?>
        {
            ["estudios"] = campoEstudios,
            ["con_apoyo"] = campoConApoyo,
            ["institucion"] = campoInstitucion,
            ["tipo"] = campoTipo
        };


        if (editando)
        {
            datos.Remove("estudios");

            var resultado = await Api.ActualizarAsync(
                "apoyo_profesoral",
                "estudios",
                campoEstudios.ToString(),
                datos
            );

            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync(
                "apoyo_profesoral",
                datos
            );

            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }


        if (exito)
        {
            mostrarFormulario = false;

            await CargarRegistros();
        }

    }


    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {

        int estudios = int.TryParse(reg["estudios"]?.ToString(), out int e) ? e : 0;

        var resultado = await Api.EliminarAsync(
            "apoyo_profesoral",
            "estudios",
            estudios.ToString()
        );

        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
        {
            await CargarRegistros();
        }

    }


    private void Cancelar()
    {
        mostrarFormulario = false;

        mensaje = string.Empty;
    }

}
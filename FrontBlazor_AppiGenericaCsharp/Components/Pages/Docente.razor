@page "/docente"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>docentes</PageTitle>

<div class="container mt-4">
    <h3>docentes</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Cliente</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar docente" : "Nuevo docente")
            </div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label"> cedula</label>
                            <input class="form-control" value="@campoCedula" disabled />
                        </div>
                    }

                     @* CÉDULA *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Cédula</label>
        <input class="form-control" type="number" @bind="campoCedula" disabled="@editando" />
    </div>

    @* NOMBRES *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Nombres</label>
        <input class="form-control" @bind="campoNombres" />
    </div>

    @* APELLIDOS *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Apellidos</label>
        <input class="form-control" @bind="campoApellidos" />
    </div>

    @* GENERO *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Género</label>
        <input class="form-control" @bind="campoGenero" />
    </div>

    @* CARGO *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Cargo</label>
        <input class="form-control" @bind="campoCargo" />
    </div>

    @* FECHA NACIMIENTO *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Fecha Nacimiento</label>
        <input class="form-control" type="date" @bind="campoFechaNacimiento" />
    </div>

    @* CORREO *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Correo</label>
        <input class="form-control" type="email" @bind="campoCorreo" />
    </div>

    @* TELEFONO *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Teléfono</label>
        <input class="form-control" @bind="campoTelefono" />
    </div>

    @* CVLAC *@
    <div class="col-md-6 mb-3">
        <label class="form-label">URL CVLAC</label>
        <input class="form-control" @bind="campoUrlCvlac" />
    </div>

    @* FECHA ACTUALIZACION *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Fecha Actualización</label>
        <input class="form-control" type="date" @bind="campoFechaActualizacion" />
    </div>

    @* ESCALAFON *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Escalafón</label>
        <input class="form-control" @bind="campoEscalafon" />
    </div>

    @* PERFIL *@
    <div class="col-md-12 mb-3">
        <label class="form-label">Perfil</label>
        <textarea class="form-control" rows="3" @bind="campoPerfil"></textarea>
    </div>

    @* CATEGORIA MINCIENCIAS *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Categoría Minciencias</label>
        <input class="form-control" @bind="campoCatMinciencia" />
    </div>

    @* CONVOCATORIA MINCIENCIAS *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Convocatoria Minciencias</label>
        <input class="form-control" @bind="campoConvMinciencia" />
    </div>

    @* NACIONALIDAD *@
    <div class="col-md-6 mb-3">
        <label class="form-label">Nacionalidad</label>
        <input class="form-control" @bind="campoNacionalidad" />
    </div>

                   

                    <div class="col-md-6 mb-3">
                        <label class="form-label">linea de investigacion</label>
                        <select class="form-select" @bind="campoLineaInvestigacion">
                            <option value="">-- Seleccione --</option>
                            @foreach (var l in lineasDeInvestigacion)
                            {
                                <option value="@l["id"]">@l["nombre"] (@l["descripcion"])</option>
                            }
                        </select>
                    </div>
                    
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                  <th>Cédula</th>
<th>Nombres</th>
<th>Apellidos</th>
<th>Género</th>
<th>Cargo</th>
<th>Fecha Nacimiento</th>
<th>Correo</th>
<th>Teléfono</th>
<th>URL CVLAC</th>
<th>Fecha Actualización</th>
<th>Escalafón</th>
<th>Perfil</th>
<th>Categoría Minciencias</th>
<th>Convocatoria Minciencias</th>
<th>Nacionalidad</th>
<th>Línea Investigación</th>
<th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                         <td>@reg["cedula"]</td>
        <td>@reg["nombres"]</td>
        <td>@reg["apellidos"]</td>
        <td>@reg["genero"]</td>
        <td>@reg["cargo"]</td>
        <td>@reg["fecha_nacimiento"]</td>
        <td>@reg["correo"]</td>
        <td>@reg["telefono"]</td>
        <td>@reg["url_cvlac"]</td>
        <td>@reg["fecha_actualizacion"]</td>
        <td>@reg["escalafon"]</td>
        <td>@reg["perfil"]</td>
        <td>@reg["cat_minciencia"]</td>
        <td>@reg["conv_minciencia"]</td>
        <td>@reg["nacionalidaad"]</td>
       <td>@ObtenerNombreLinea(reg["linea_investigacion_principal"]?.ToString())</td>
         
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla cliente.</div>
    }
</div>

@code {

    private List<Dictionary<string, object?>> lineasDeInvestigacion = new();
        private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

   private string campoCedula = string.Empty;
private string campoNombres = string.Empty;
private string campoApellidos = string.Empty;
private string campoGenero = string.Empty;
private string campoCargo = string.Empty;
private DateTime campoFechaNacimiento;
private string campoCorreo = string.Empty;
private string campoTelefono = string.Empty;
private string campoUrlCvlac = string.Empty;
private DateTime campoFechaActualizacion;
private string campoEscalafon = string.Empty;
private string campoPerfil = string.Empty;
private string? campoCatMinciencia = null;
private string campoConvMinciencia = string.Empty;
private string campoNacionalidad = string.Empty;
private string campoLineaInvestigacion = string.Empty;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        lineasDeInvestigacion = await Api.ListarAsync("linea_investigacion");
   
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("docente");
        cargando = false;
    }

    private string ObtenerNombreLinea(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "Sin persona";
        var lineaInvestig = lineasDeInvestigacion.FirstOrDefault(p => p["id"]?.ToString() == id);
        return lineaInvestig?["nombre"]?.ToString() ?? id;
    }


    private void NuevoRegistro()
    {
        editando = false;
          mostrarFormulario = true;
               mensaje = string.Empty;
       campoCedula = string.Empty;
campoNombres = string.Empty;
campoApellidos = string.Empty;
campoGenero = string.Empty;
campoCargo = string.Empty;
campoFechaNacimiento = DateTime.Now;
campoCorreo = string.Empty;
campoTelefono = string.Empty;
campoUrlCvlac = string.Empty;
campoFechaActualizacion = DateTime.Now;
campoEscalafon = string.Empty;
campoPerfil = string.Empty;
campoCatMinciencia = null;
campoConvMinciencia = string.Empty;
campoNacionalidad = string.Empty;
campoLineaInvestigacion = string.Empty; 


    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
      campoCedula = reg["cedula"]?.ToString() ?? "";

campoNombres = reg["nombres"]?.ToString() ?? "";
campoApellidos = reg["apellidos"]?.ToString() ?? "";
campoGenero = reg["genero"]?.ToString() ?? "";
campoCargo = reg["cargo"]?.ToString() ?? "";

campoFechaNacimiento = DateTime.TryParse(reg["fecha_nacimiento"]?.ToString(), out DateTime fn)
    ? fn : DateTime.Now;

campoCorreo = reg["correo"]?.ToString() ?? "";
campoTelefono = reg["telefono"]?.ToString() ?? "";
campoUrlCvlac = reg["url_cvlac"]?.ToString() ?? "";

campoFechaActualizacion = DateTime.TryParse(reg["fecha_actualizacion"]?.ToString(), out DateTime fa)
    ? fa : DateTime.Now;

campoEscalafon = reg["escalafon"]?.ToString() ?? "";
campoPerfil = reg["perfil"]?.ToString() ?? "";

campoCatMinciencia = reg["cat_minciencia"]?.ToString();

campoConvMinciencia = reg["conv_minciencia"]?.ToString() ?? "";
campoNacionalidad = reg["nacionalidaad"]?.ToString() ?? "";


        campoLineaInvestigacion = reg["linea_investigacion_principal"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
          ["cedula"] = campoCedula,
    ["nombres"] = campoNombres,
    ["apellidos"] = campoApellidos,
    ["genero"] = campoGenero,
    ["cargo"] = campoCargo,
    ["fecha_nacimiento"] = campoFechaNacimiento,
    ["correo"] = campoCorreo,
    ["telefono"] = campoTelefono,
    ["url_cvlac"] = campoUrlCvlac,
    ["fecha_actualizacion"] = campoFechaActualizacion,
    ["escalafon"] = campoEscalafon,
    ["perfil"] = campoPerfil,
    ["cat_minciencia"] = string.IsNullOrWhiteSpace(campoCatMinciencia) ? null : campoCatMinciencia,
    ["conv_minciencia"] = campoConvMinciencia,
    ["nacionalidaad"] = campoNacionalidad,
    ["linea_investigacion_principal"] = string.IsNullOrEmpty(campoLineaInvestigacion) ? null : campoLineaInvestigacion
        };

        if (editando)
        {
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de actualizar el Cliente #{campoCedula}?");
            if (!confirmar) return;
            var resultado = await Api.ActualizarAsync("docente", "cedula", campoCedula, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("docente", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["cedula"]?.ToString() ?? "";
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de eliminar el Cliente #{id}?");
        if (!confirmar) return;
        var resultado = await Api.EliminarAsync("docente", "cedula", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}